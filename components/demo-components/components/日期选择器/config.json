{
  "type": "datepicker",
  "label": "日期选择器",
  "icon": "icon.svg",
  "width": 140,
  "height": 28,
  "text": "",
  "preview": {
    "html": "<input type=\"text\" style=\"width:100%;height:100%;border:1px solid #a0a0a0;border-radius:4px;padding:0 6px;font-size:12px;box-sizing:border-box;\" value=\"{{value}}\" placeholder=\"{{format}}\" readonly />"
  },
  "runtime": {
    "html": "<input type=\"text\" style=\"width:100%;height:100%;border:1px solid #a0a0a0;border-radius:4px;padding:0 6px;font-size:12px;box-sizing:border-box;\" value=\"{{value}}\" placeholder=\"{{format}}\" />",
    "events": {
      "change": "值被改变",
      "focus": "获得焦点",
      "blur": "失去焦点"
    }
  },
  "props": [
    {
      "key": "format",
      "label": "格式",
      "type": "text",
      "default": "yyyy-MM-dd"
    },
    {
      "key": "mode",
      "label": "模式",
      "type": "select",
      "default": "date",
      "options": [
        { "label": "日期", "value": "date" },
        { "label": "日期时间", "value": "datetime" },
        { "label": "时间", "value": "time" }
      ]
    },
    {
      "key": "clearable",
      "label": "可清空",
      "type": "bool",
      "default": true
    },
    {
      "key": "value",
      "label": "当前值",
      "type": "text",
      "default": ""
    }
  ],
  "events": ["值被改变", "获得焦点", "失去焦点"]
}
