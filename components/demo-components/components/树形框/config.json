{
  "type": "treeview",
  "label": "树形框",
  "icon": "",
  "width": 160,
  "height": 120,
  "text": "",
  "props": [
    {
      "key": "showLines",
      "label": "显示连线",
      "type": "bool",
      "default": true
    },
    {
      "key": "checkable",
      "label": "可勾选",
      "type": "bool",
      "default": false
    },
    {
      "key": "expandAll",
      "label": "默认展开",
      "type": "bool",
      "default": true
