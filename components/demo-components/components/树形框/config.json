    {
      "key": "indent",
      "label": "缩进",
      "type": "number",
      "default": 16,
      "min": 0,
      "max": 60,
      "step": 2
    }
  ],
  "events": ["节点被点击", "节点被展开", "节点被收缩", "勾选被改变"]
