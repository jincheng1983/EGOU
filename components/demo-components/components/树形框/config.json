{
  "type": "treeview",
  "label": "树形框",
  "icon": "icon.svg",
  "width": 160,
  "height": 120,
  "text": "",
  "preview": {
    "html": "<div style=\"width:100%;height:100%;border:1px solid #a0a0a0;border-radius:4px;padding:4px 6px;font-size:11px;overflow:hidden;box-sizing:border-box;background:#fff;color:#333;\"><div style=\"margin-bottom:2px;\">📁 根节点</div><div style=\"padding-left:{{indent}}px;\">📁 子节点1</div><div style=\"padding-left:{{indent}}px;\">📁 子节点2</div><div style=\"padding-left:{{indent}}px;\">📄 叶子节点</div></div>"
  },
  "props": [
    {
      "key": "showLines",
      "label": "显示连线",
      "type": "bool",
      "default": true
    },
    {
      "key": "checkable",
      "label": "可勾选",
      "type": "bool",
      "default": false
    },
    {
      "key": "expandAll",
      "label": "默认展开",
      "type": "bool",
      "default": true
    },
    {
      "key": "indent",
      "label": "缩进",
      "type": "number",
      "default": 16,
      "min": 0,
      "max": 60,
      "step": 2
    }
  ],
  "events": ["节点被点击", "节点被展开", "节点被收缩", "勾选被改变"]
}
